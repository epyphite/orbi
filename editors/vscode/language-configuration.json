{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "'", "close": "'", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["'", "'"]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*--\\s*──",
      "end": "^\\s*$"
    }
  },
  "wordPattern": "@?[a-zA-Z_][a-zA-Z0-9_]*"
}
