--   WHERE active_state = 'failed';
--
-- SELECT * FROM docker_containers('earth-ssh');
--
-- SELECT valid, errors FROM nginx_config_test('earth-ssh');
--
-- SELECT * FROM nginx_vhosts('earth-ssh');
